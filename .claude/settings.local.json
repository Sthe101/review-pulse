{
  "permissions": {
    "allow": [
      "Bash(npx --yes create-next-app@latest . --typescript --tailwind --app --src-dir --no-import-alias --eslint --use-npm --no-turbopack --yes)",
      "Bash(npm install *)",
      "Bash(npm run *)",
      "Skill(update-config)",
      "Bash(node *)",
      "Bash(pip --version)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/evaluate.sh",
            "timeout": 20
          }
        ]
      }
    ]
  }
}
